{
  "name": "gulp-chokeless-benchmarks",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bench:compress": "node run-bench.mjs -s compress-hash-js -p \"node_modules/**/*.js\"",
    "bench:md-html": "node run-bench.mjs -s md-to-html -p \"node_modules/**/*.md\"",
    "bench:json": "node run-bench.mjs -s validate-json -p \"node_modules/**/package.json\""
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "gulp": "^5.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  }
}
