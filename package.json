{
  "name": "gulp-chokeless",
  "version": "1.0.0",
  "description": "High-performance, multithreaded stream orchestrator for Gulp via worker_threads",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 3",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "gulpplugin",
    "gulp",
    "worker-threads",
    "multithreading",
    "concurrency",
    "performance",
    "stream",
    "task-runner",
    "gulp-chokeless"
  ],
  "author": "Dmytro Shovchko",
  "license": "MIT",
  "peerDependencies": {
    "gulp": ">=5.0.0"
  },
  "devDependencies": {
    "@exadel/eslint-config-esl": "^6.0.0-beta.5",
    "@types/less": "^3.0.8",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
